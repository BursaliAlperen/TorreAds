-- // DYNAMIC REMOTE DETECTION
local Remotes = {
    Coin = nil,
    Knife = nil,
    Gun = nil
}

local function scanRemotes()
    for _, v in ipairs(ReplicatedStorage:GetDescendants()) do
        if v:IsA("RemoteEvent") then
            local name = v.Name:lower()
            if (name:find("coin") or name:find("collect")) and not Remotes.Coin then
                Remotes.Coin = v
            elseif (name:find("knife") or name:find("murder") or name:find("slash")) and not Remotes.Knife then
                Remotes.Knife = v
            elseif (name:find("shoot") or name:find("gun") or name:find("fire")) and not Remotes.Gun then
                Remotes.Gun = v
            end
        end
    end
    -- Fallbacks if not found
    Remotes.Coin = Remotes.Coin or ReplicatedStorage:FindFirstChild("PickupCoin")
    Remotes.Knife = Remotes.Knife or ReplicatedStorage:FindFirstChild("KnifeHit")
    Remotes.Gun = Remotes.Gun or ReplicatedStorage:FindFirstChild("ShootGun")
end
scanRemotes()

