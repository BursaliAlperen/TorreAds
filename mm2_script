-- // UTILS
local function getRole(plr)
    if not plr or not plr.Character then return "innocent" end
    if plr.Backpack:FindFirstChild("Knife") or plr.Character:FindFirstChild("Knife") then return "murderer" end
    if plr.Backpack:FindFirstChild("Gun") or plr.Character:FindFirstChild("Gun") then return "sheriff" end
    return "innocent"
end

local function smoothMove(targetPos)
    local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local distance = (hrp.Position - targetPos).Magnitude
    local speed = 25 -- Studs per second
    local duration = distance / speed
    local tween = TweenService:Create(hrp, TweenInfo.new(duration, Enum.EasingStyle.Linear), {CFrame = CFrame.new(targetPos)})
    tween:Play()
    return tween
end

